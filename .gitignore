# ==========================================
# Spring Boot / Maven
# ==========================================

**/target/
**/build/
out/
bin/

*.class
*.jar
*.war
*.ear

# ==========================================
# Maven Wrapper
# ==========================================

# Usually this file SHOULD be committed.
# Uncomment only if you intentionally want to ignore it.

# .mvn/wrapper/maven-wrapper.jar

