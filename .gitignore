# ==========================================

# Eclipse workspace metadata
.metadata/
**/.metadata/

# Eclipse project files
.apt_generated
**/.classpath
.factorypath
**/.project
**/.settings/

# STS cache
.springBeans
.sts4-cache

# ==========================================
